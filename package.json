{
  "name": "GSTR1-Offline",
  "version": "2.2.3",
  "description": "GST Offline Tool for Linux",
  "main": "app.js",
  "bin": "app.js",
  "node-main": "./app.js",
  "private": true,
  "scripts": {
    "start": "node app.js",
    "build": "pkg . --targets node18-linux-x64 --output gst-backend"
  },
  "pkg": {
    "assets": [
      "views/**/*",
      "public/**/*",
      "icon/**/*",
      "node_modules/jade/**/*"
    ],
    "scripts": [
      "routes/**/*.js"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.4.7",
    "async": "^2.3.0",
    "body-parser": "^1.17.1",
    "cookie-parser": "^1.4.3",
    "debug": "^2.6.3",
    "del": "^2.2.2",
    "delete": "^1.0.1",
    "excel4node": "^1.7.2",
    "express": "^4.15.2",
    "fs": "^0.0.2",
    "http": "0.0.0",
    "jade": "^0.29.0",
    "json-size": "^1.0.0",
    "jsonschema": "^1.2.6",
    "utf8-length": "^0.0.1",
    "logger": "^0.0.1",
    "mkdirp": "^0.5.1",
    "moment": "^2.18.1",
    "morgan": "^1.8.1",
    "multer": "^1.3.0",
    "node-cache": "^4.1.1",
    "node-native-zip": "^1.1.0",
    "node.extend": "^2.0.0",
    "omit-empty": "^0.4.1",
    "path": "^0.12.7",
    "underscore": "^1.8.3",
    "winston": "^2.3.1",
    "xlsx": "^0.10.7"
  }
}
